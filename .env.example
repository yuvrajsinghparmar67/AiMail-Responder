# Copy to .env and fill in your values before running docker-compose up
# or the backend/frontend dev servers.

# --- Backend --------------------------------------------------------------
ENVIRONMENT=development
DATABASE_URL=sqlite:///./data/app.db

# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list; the frontend origin(s) allowed to call the API
CORS_ORIGINS=http://localhost:3000

# Google Gemini API — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
CHAT_MODEL=gemini-3.5-flash
EMBEDDING_MODEL=gemini-embedding-2

RATE_LIMIT_GENERATE=20/minute
RATE_LIMIT_AUTH=10/minute

LOG_LEVEL=INFO

# --- Frontend ---------------------------------------------------------
# Must be set at Docker build time (see docker-compose.yml build args)
# since Next.js inlines NEXT_PUBLIC_* variables at build, not runtime.
NEXT_PUBLIC_API_URL=http://localhost:8000
